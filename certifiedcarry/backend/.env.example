# CertifiedCarry backend environment template
# Copy this file to .env in the same folder and replace placeholder values.
# File location: backend/certifiedcarry-api/.env

# Server
SERVER_PORT=8000

# Actuator (keep public surface minimal)
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=never
MANAGEMENT_ENDPOINT_HEALTH_PROBES_ENABLED=true

# CORS (set this to your deployed frontend domain(s) before production)
SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:3005,http://127.0.0.1:3005
SECURITY_CORS_ALLOWED_METHODS=GET,POST,PATCH,DELETE,OPTIONS
SECURITY_CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept,X-Requested-With,X-Request-Id
SECURITY_CORS_EXPOSED_HEADERS=X-Request-Id,Retry-After
SECURITY_CORS_MAX_AGE_SECONDS=3600
SECURITY_CORS_ALLOW_CREDENTIALS=false
# Set true in production to fail startup on wildcard, localhost, or non-HTTPS origins.
SECURITY_CORS_ENFORCE_PRODUCTION_SAFE_ORIGINS=false

# Database
DB_URL=jdbc:postgresql://localhost:5432/app_database
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Firebase Admin
FIREBASE_ENABLED=true
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/firebase-service-account.json

# Object storage (DigitalOcean Spaces / S3-compatible uploads)
OBJECT_STORAGE_ENABLED=false
OBJECT_STORAGE_ENDPOINT=https://nyc3.digitaloceanspaces.com
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=your-space-name
OBJECT_STORAGE_ACCESS_KEY=YOUR_SPACES_KEY
OBJECT_STORAGE_SECRET_KEY=YOUR_SPACES_SECRET
OBJECT_STORAGE_KEY_PREFIX=player-assets
OBJECT_STORAGE_PUBLIC_BASE_URL=https://your-space-name.nyc3.digitaloceanspaces.com
OBJECT_STORAGE_PRESIGN_EXPIRY_SECONDS=600
OBJECT_STORAGE_MAX_UPLOAD_BYTES=6291456

# Legal policy versions
LEGAL_TERMS_ACTIVE_VERSION=your-terms-version
LEGAL_PRIVACY_ACTIVE_VERSION=your-privacy-version

# Deferred Firebase account deletion queue
ACCOUNT_DELETION_FIREBASE_RETRY_DELAY_MS=60000
ACCOUNT_DELETION_FIREBASE_RETRY_BATCH_SIZE=25
ACCOUNT_DELETION_FIREBASE_RETRY_BASE_DELAY_SECONDS=30
ACCOUNT_DELETION_FIREBASE_RETRY_MAX_DELAY_SECONDS=3600

# Notification emails
NOTIFICATIONS_EMAIL_ENABLED=true
NOTIFICATIONS_EMAIL_FROM=no-reply@example.com
NOTIFICATIONS_EMAIL_REPLY_TO=support@example.com
NOTIFICATIONS_EMAIL_APP_BASE_URL=https://app.example.com
NOTIFICATIONS_RANK_VALIDATION_VALIDITY_DAYS=30
NOTIFICATIONS_RANK_EXPIRY_REMINDER_HOURS=24
NOTIFICATIONS_RANK_EXPIRY_CHECK_DELAY_MS=900000
NOTIFICATIONS_RANK_EXPIRY_BATCH_SIZE=100
# Send security alert emails when an ADMIN account logs in.
NOTIFICATIONS_SECURITY_ADMIN_LOGIN_ALERT_EMAIL=your-alert-email@example.com

# SMTP (Brevo)
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=YOUR_BREVO_SMTP_USERNAME
MAIL_PASSWORD=YOUR_BREVO_SMTP_KEY
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
